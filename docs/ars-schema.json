{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ARS Audit - Brand Analyst Output",
  "description": "Schema for the Brand Analyst's raw output. Consumed by Brand Architect.",
  "type": "object",
  "required": ["brand", "domain", "audit_date", "prompts", "results"],
  "properties": {
    "brand": { "type": "string", "description": "Brand name as audited" },
    "domain": { "type": "string", "description": "Primary domain (e.g. gimber.be)" },
    "audit_date": { "type": "string", "format": "date", "description": "YYYY-MM-DD" },
    "prompts": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": { "type": "string" },
      "description": "5 purchase-intent prompts used to probe all platforms"
    },
    "results": {
      "type": "object",
      "required": ["chatgpt", "perplexity", "gemini", "claude"],
      "properties": {
        "chatgpt":    { "$ref": "#/$defs/platform_result" },
        "perplexity": { "$ref": "#/$defs/platform_result" },
        "gemini":     { "$ref": "#/$defs/platform_result" },
        "claude":     { "$ref": "#/$defs/platform_result" }
      }
    }
  },
  "$defs": {
    "platform_result": {
      "type": "object",
      "required": ["score", "appearances", "competitors", "misinformation"],
      "properties": {
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "(appearances / total_prompts) × 100"
        },
        "appearances": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5,
          "description": "Number of prompts where brand appeared in response"
        },
        "competitors": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Competing brands that appeared in responses"
        },
        "misinformation": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Any false or outdated claims about the brand found in responses"
        },
        "simulated": {
          "type": "boolean",
          "default": false,
          "description": "True if live API was unavailable and responses were simulated"
        }
      }
    }
  }
}
